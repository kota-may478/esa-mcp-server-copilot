# esa API 認証
ESA_ACCESS_TOKEN=your_esa_personal_access_token
ESA_TEAM_NAME=your-team-name

# API 設定
ESA_API_BASE_URL=https://api.esa.io/v1
ESA_HTTP_TIMEOUT_MS=15000

# ログ設定 (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# HTTP モード (任意)
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8787
MCP_AUTH_TOKEN=replace-with-a-long-random-token
